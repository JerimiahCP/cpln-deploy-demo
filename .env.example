# ─────────────────────────────────────────────────────────────────────────────
# Local development environment
# Copy this file to .env and fill in the values you need.
#
# In Control Plane these are set in cpln/workload.yaml under spec.containers.env
# The [cpln] variables are injected automatically at runtime — don't set them
# in the workload YAML, Control Plane provides them.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
PORT=8080
ENVIRONMENT=local

# ── Storage ───────────────────────────────────────────────────────────────────
# 'local' writes to DATA_DIR on disk — no cloud credentials needed
# 's3'    writes to S3 — set AWS_* vars below and ensure credentials are available
STORAGE_BACKEND=local

# Local storage path (only used when STORAGE_BACKEND=local)
DATA_DIR=./data

# S3 config (only used when STORAGE_BACKEND=s3)
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# AWS credentials for local S3 development.
# In Control Plane these are never set — the workload identity injects
# temporary STS credentials automatically via cpln/identity.yaml.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Limits ───────────────────────────────────────────────────────────────────
MAX_UPLOAD_MB=25

# ── Control Plane runtime ────────────────────────────────────────────────────
# These are injected automatically by Control Plane. Do not set in production.
# Shown here for reference and local testing only.
#
# CPLN_ORG=             # your org name
# CPLN_GVC=             # your GVC name
# CPLN_WORKLOAD_NAME=   # your workload name
# CPLN_LOCATION=        # e.g. //location/aws-us-east-1  (full resource path)
